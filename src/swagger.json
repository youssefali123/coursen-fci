{
  "openapi": "3.0.1",
  "info": {
    "title": "ELProject",
    "version": "1.0"
  },
  "paths": {
    "/api/Auth/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "Password",
                  "Role",
                  "Username"
                ],
                "type": "object",
                "properties": {
                  "Username": {
                    "maxLength": 50,
                    "minLength": 3,
                    "pattern": "^[a-zA-Z0-9_]+$",
                    "type": "string"
                  },
                  "Email": {
                    "maxLength": 254,
                    "minLength": 0,
                    "type": "string",
                    "format": "email"
                  },
                  "Password": {
                    "maxLength": 100,
                    "minLength": 8,
                    "pattern": "^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[\\W_]).+$",
                    "type": "string"
                  },
                  "Bio": {
                    "type": "string"
                  },
                  "Role": {
                    "$ref": "#/components/schemas/UserRole"
                  },
                  "Gender": {
                    "$ref": "#/components/schemas/Gender"
                  },
                  "ProfileImageFile": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "Username": {
                  "style": "form"
                },
                "Email": {
                  "style": "form"
                },
                "Password": {
                  "style": "form"
                },
                "Bio": {
                  "style": "form"
                },
                "Role": {
                  "style": "form"
                },
                "Gender": {
                  "style": "form"
                },
                "ProfileImageFile": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
